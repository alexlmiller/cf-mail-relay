---
const apiBase = import.meta.env.PUBLIC_CF_MAIL_RELAY_API_BASE ?? "";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cloudflare Mail Relay</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f6f7f9;
        --panel: #ffffff;
        --ink: #17202a;
        --muted: #647184;
        --line: #d8dee8;
        --accent: #0f766e;
        --accent-ink: #ffffff;
        --danger: #b42318;
        --warn: #ad6f00;
        --ok: #157347;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        min-width: 320px;
        background: var(--bg);
        color: var(--ink);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        font-size: 14px;
        letter-spacing: 0;
      }
      button,
      input,
      select {
        font: inherit;
      }
      .shell {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 240px minmax(0, 1fr);
      }
      aside {
        border-right: 1px solid var(--line);
        background: #111827;
        color: #f9fafb;
        padding: 18px 14px;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 700;
        margin-bottom: 20px;
      }
      .mark {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        display: grid;
        place-items: center;
        background: #f97316;
        color: #111827;
        font-weight: 800;
      }
      nav {
        display: grid;
        gap: 4px;
      }
      .tab {
        border: 0;
        border-radius: 6px;
        background: transparent;
        color: #d1d5db;
        cursor: pointer;
        padding: 9px 10px;
        text-align: left;
      }
      .tab[aria-selected="true"] {
        background: #263244;
        color: #ffffff;
      }
      main {
        min-width: 0;
      }
      header {
        min-height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 14px 22px;
        border-bottom: 1px solid var(--line);
        background: var(--panel);
      }
      h1 {
        margin: 0;
        font-size: 20px;
        line-height: 1.2;
      }
      .status {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--muted);
        min-width: 0;
      }
      .dot {
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: var(--warn);
      }
      .dot.ok {
        background: var(--ok);
      }
      .content {
        padding: 20px 22px 40px;
        display: grid;
        gap: 18px;
      }
      .metrics {
        display: grid;
        grid-template-columns: repeat(4, minmax(160px, 1fr));
        gap: 12px;
      }
      .metric,
      .panel {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 8px;
      }
      .metric {
        padding: 14px;
      }
      .metric span {
        display: block;
        color: var(--muted);
        font-size: 12px;
        margin-bottom: 8px;
      }
      .metric strong {
        font-size: 24px;
      }
      .panel-header {
        min-height: 52px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 14px;
        border-bottom: 1px solid var(--line);
      }
      .panel-header h2 {
        margin: 0;
        font-size: 16px;
      }
      .toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
      }
      .button {
        border: 1px solid var(--line);
        border-radius: 6px;
        background: #ffffff;
        color: var(--ink);
        cursor: pointer;
        padding: 7px 10px;
      }
      .button.primary {
        border-color: var(--accent);
        background: var(--accent);
        color: var(--accent-ink);
      }
      .table-wrap {
        overflow-x: auto;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        min-width: 760px;
      }
      th,
      td {
        padding: 10px 12px;
        border-bottom: 1px solid var(--line);
        text-align: left;
        vertical-align: top;
        white-space: nowrap;
      }
      th {
        color: var(--muted);
        font-size: 12px;
        font-weight: 650;
        background: #fafbfc;
      }
      td {
        max-width: 340px;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .pill {
        border-radius: 999px;
        padding: 3px 8px;
        font-size: 12px;
        background: #eef2f7;
        color: #334155;
      }
      .pill.ok {
        color: var(--ok);
        background: #e9f7ef;
      }
      .pill.bad {
        color: var(--danger);
        background: #fdecec;
      }
      dialog {
        width: min(560px, calc(100vw - 28px));
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 0;
      }
      dialog::backdrop {
        background: rgb(17 24 39 / 0.55);
      }
      form {
        display: grid;
        gap: 12px;
        padding: 14px;
      }
      label {
        display: grid;
        gap: 5px;
        color: var(--muted);
        font-size: 12px;
      }
      input,
      select {
        min-height: 36px;
        border: 1px solid var(--line);
        border-radius: 6px;
        padding: 7px 9px;
        color: var(--ink);
      }
      .secret {
        margin: 0 14px 14px;
        padding: 12px;
        border-radius: 6px;
        border: 1px solid #f6c453;
        background: #fff7df;
        overflow-wrap: anywhere;
      }
      .error {
        color: var(--danger);
      }
      @media (max-width: 860px) {
        .shell {
          grid-template-columns: 1fr;
        }
        aside {
          position: sticky;
          top: 0;
          z-index: 2;
          border-right: 0;
          border-bottom: 1px solid #263244;
        }
        nav {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
        .metrics {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
        header {
          align-items: flex-start;
          flex-direction: column;
        }
      }
      @media (max-width: 520px) {
        .metrics,
        nav {
          grid-template-columns: 1fr;
        }
        .content {
          padding-inline: 12px;
        }
        header {
          padding-inline: 12px;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell" data-api-base={apiBase}>
      <aside>
        <div class="brand"><div class="mark">CF</div><span>Mail Relay</span></div>
        <nav aria-label="Admin sections">
          <button class="tab" data-view="dashboard" aria-selected="true">Dashboard</button>
          <button class="tab" data-view="domains">Domains</button>
          <button class="tab" data-view="senders">Senders</button>
          <button class="tab" data-view="credentials">SMTP Credentials</button>
          <button class="tab" data-view="users">Users</button>
          <button class="tab" data-view="events">Events</button>
          <button class="tab" data-view="failures">Auth Failures</button>
          <button class="tab" data-view="apiKeys">API Keys</button>
        </nav>
      </aside>
      <main>
        <header>
          <h1 id="view-title">Dashboard</h1>
          <div class="status"><span class="dot" id="status-dot"></span><span id="session">Checking Access</span></div>
        </header>
        <section class="content" id="app"></section>
      </main>
    </div>
    <dialog id="modal"></dialog>
    <script>
      // @ts-nocheck
      const root = document.querySelector(".shell");
      const apiBase = root?.dataset.apiBase || "";
      const app = document.querySelector("#app");
      const title = document.querySelector("#view-title");
      const session = document.querySelector("#session");
      const statusDot = document.querySelector("#status-dot");
      const modal = document.querySelector("#modal");
      const tabs = Array.from(document.querySelectorAll(".tab"));
      let state = { users: [], domains: [], senders: [] };
      const views = {
        dashboard: { title: "Dashboard", load: loadDashboard },
        domains: { title: "Domains", load: loadDomains },
        senders: { title: "Senders", load: loadSenders },
        credentials: { title: "SMTP Credentials", load: loadCredentials },
        users: { title: "Users", load: loadUsers },
        events: { title: "Events", load: loadEvents },
        failures: { title: "Auth Failures", load: loadFailures },
        apiKeys: { title: "API Keys", load: loadApiKeys },
      };

      init();

      async function init() {
        tabs.forEach((tab) => tab.addEventListener("click", () => show(tab.dataset.view)));
        await loadSession();
        await show("dashboard");
      }

      async function request(path, options = {}) {
        const response = await fetch(`${apiBase}${path}`, {
          ...options,
          credentials: "include",
          headers: { "content-type": "application/json", ...(options.headers || {}) },
        });
        const payload = await response.json();
        if (!response.ok || payload.ok === false) {
          throw new Error(payload.error || response.statusText);
        }
        return payload.result ?? payload;
      }

      async function loadSession() {
        try {
          const payload = await request("/admin/api/session");
          statusDot.classList.add("ok");
          session.textContent = payload.user.email;
        } catch (error) {
          statusDot.classList.remove("ok");
          session.textContent = error.message;
        }
      }

      async function show(name) {
        const view = views[name] || views.dashboard;
        tabs.forEach((tab) => tab.setAttribute("aria-selected", String(tab.dataset.view === name)));
        title.textContent = view.title;
        app.innerHTML = "";
        try {
          await view.load();
        } catch (error) {
          app.innerHTML = `<div class="panel"><div class="panel-header"><h2 class="error">${escapeHtml(error.message)}</h2><button class="button" id="retry">Retry</button></div></div>`;
          document.querySelector("#retry")?.addEventListener("click", () => show(name));
        }
      }

      async function loadDashboard() {
        const data = await request("/admin/api/dashboard");
        app.innerHTML = `
          <div class="metrics">
            ${metric("Accepted 24h", data.sends_24h.accepted)}
            ${metric("Failed 24h", data.sends_24h.failed)}
            ${metric("Auth Failures", data.auth_failures_24h)}
            ${metric("Credentials", data.resource_counts.smtp_credentials)}
          </div>
          ${panel("Latest Send Events", "", table(["Time", "Status", "From", "Recipients", "SMTP"], await request("/admin/api/send-events"), eventRow))}
        `;
      }

      async function loadUsers() {
        state.users = await request("/admin/api/users");
        app.innerHTML = panel("Users", `<button class="button primary" id="new-user">New User</button>`, table(["Email", "Role", "Access Subject", "State"], state.users, userRow));
        document.querySelector("#new-user")?.addEventListener("click", userForm);
      }

      async function loadDomains() {
        state.domains = await request("/admin/api/domains");
        app.innerHTML = panel("Domains", `<button class="button primary" id="new-domain">New Domain</button>`, table(["Domain", "Status", "Zone", "Enabled"], state.domains, domainRow));
        document.querySelector("#new-domain")?.addEventListener("click", domainForm);
      }

      async function loadSenders() {
        await preloadRefs();
        app.innerHTML = panel("Allowed Senders", `<button class="button primary" id="new-sender">New Sender</button>`, table(["Address", "Domain", "User", "State"], state.senders, senderRow));
        document.querySelector("#new-sender")?.addEventListener("click", senderForm);
      }

      async function loadCredentials() {
        await preloadRefs();
        const rows = await request("/admin/api/smtp-credentials");
        app.innerHTML = panel("SMTP Credentials", `<button class="button primary" id="new-credential">New Credential</button>`, table(["Name", "Username", "User", "Last Used", "State", ""], rows, credentialRow));
        document.querySelector("#new-credential")?.addEventListener("click", credentialForm);
        document.querySelectorAll("[data-revoke]").forEach((button) => button.addEventListener("click", async () => {
          await request(`/admin/api/smtp-credentials/${button.dataset.revoke}/revoke`, { method: "POST", body: "{}" });
          await show("credentials");
        }));
      }

      async function loadEvents() {
        app.innerHTML = panel("Send Events", "", table(["Time", "Status", "From", "Recipients", "Credential", "Error"], await request("/admin/api/send-events"), eventRowFull));
      }

      async function loadFailures() {
        app.innerHTML = panel("Auth Failures", "", table(["Time", "Username", "Reason", "Source"], await request("/admin/api/auth-failures"), failureRow));
      }

      async function loadApiKeys() {
        app.innerHTML = panel("API Keys", "", table(["Name", "Prefix", "User", "Last Used", "State"], await request("/admin/api/api-keys"), apiKeyRow));
      }

      async function preloadRefs() {
        const [users, domains, senders] = await Promise.all([
          request("/admin/api/users"),
          request("/admin/api/domains"),
          request("/admin/api/senders"),
        ]);
        state = { users, domains, senders };
      }

      function userForm() {
        openForm("New User", [
          field("email", "Email"),
          field("display_name", "Display Name"),
          select("role", "Role", [["admin", "admin"], ["sender", "sender"]]),
        ], async (body) => {
          await request("/admin/api/users", { method: "POST", body: JSON.stringify(body) });
          await show("users");
        });
      }

      function domainForm() {
        openForm("New Domain", [
          field("domain", "Domain"),
          field("cloudflare_zone_id", "Zone ID"),
          select("status", "Status", [["pending", "pending"], ["verified", "verified"], ["sandbox", "sandbox"], ["disabled", "disabled"]]),
        ], async (body) => {
          await request("/admin/api/domains", { method: "POST", body: JSON.stringify(body) });
          await show("domains");
        });
      }

      function senderForm() {
        openForm("New Sender", [
          select("domain_id", "Domain", state.domains.map((domain) => [domain.id, domain.domain])),
          field("email", "Email"),
          select("user_id", "User", [["", "unassigned"], ...state.users.map((user) => [user.id, user.email])]),
        ], async (body) => {
          if (!body.user_id) delete body.user_id;
          await request("/admin/api/senders", { method: "POST", body: JSON.stringify(body) });
          await show("senders");
        });
      }

      function credentialForm() {
        openForm("New SMTP Credential", [
          select("user_id", "User", state.users.map((user) => [user.id, user.email])),
          field("name", "Name"),
          field("username", "Username"),
        ], async (body) => {
          const result = await request("/admin/api/smtp-credentials", { method: "POST", body: JSON.stringify(body) });
          modal.querySelector(".secret-slot").innerHTML = `<div class="secret"><strong>${escapeHtml(result.username)}</strong><br>${escapeHtml(result.secret)}</div>`;
          await show("credentials");
        }, true);
      }

      function openForm(heading, controls, submit, keepOpen = false) {
        modal.innerHTML = `
          <div class="panel-header"><h2>${escapeHtml(heading)}</h2><button class="button" value="cancel" formmethod="dialog">Close</button></div>
          <form method="dialog">
            ${controls.join("")}
            <div class="toolbar"><button class="button primary" value="submit">Save</button><button class="button" value="cancel">Cancel</button></div>
          </form>
          <div class="secret-slot"></div>
        `;
        const form = modal.querySelector("form");
        form.addEventListener("submit", async (event) => {
          event.preventDefault();
          if (event.submitter?.value === "cancel") {
            modal.close();
            return;
          }
          const data = Object.fromEntries(new FormData(form).entries());
          await submit(data);
          if (!keepOpen) modal.close();
        });
        modal.showModal();
      }

      function metric(label, value) {
        return `<div class="metric"><span>${escapeHtml(label)}</span><strong>${Number(value || 0).toLocaleString()}</strong></div>`;
      }

      function panel(heading, tools, body) {
        return `<section class="panel"><div class="panel-header"><h2>${escapeHtml(heading)}</h2><div class="toolbar">${tools}</div></div>${body}</section>`;
      }

      function table(headers, rows, render) {
        return `<div class="table-wrap"><table><thead><tr>${headers.map((header) => `<th>${escapeHtml(header)}</th>`).join("")}</tr></thead><tbody>${rows.map(render).join("") || `<tr><td colspan="${headers.length}">No rows</td></tr>`}</tbody></table></div>`;
      }

      function field(name, label) {
        return `<label>${escapeHtml(label)}<input name="${escapeHtml(name)}" /></label>`;
      }

      function select(name, label, options) {
        return `<label>${escapeHtml(label)}<select name="${escapeHtml(name)}">${options.map(([value, text]) => `<option value="${escapeHtml(value)}">${escapeHtml(text)}</option>`).join("")}</select></label>`;
      }

      function userRow(row) {
        return `<tr><td>${escapeHtml(row.email)}</td><td>${escapeHtml(row.role)}</td><td>${escapeHtml(row.access_subject || "")}</td><td>${statePill(row.disabled_at ? "disabled" : "active")}</td></tr>`;
      }

      function domainRow(row) {
        return `<tr><td>${escapeHtml(row.domain)}</td><td>${statePill(row.status)}</td><td>${escapeHtml(row.cloudflare_zone_id || "")}</td><td>${row.enabled ? "yes" : "no"}</td></tr>`;
      }

      function senderRow(row) {
        return `<tr><td>${escapeHtml(row.email)}</td><td>${escapeHtml(row.domain)}</td><td>${escapeHtml(row.user_email || "")}</td><td>${statePill(row.enabled ? "enabled" : "disabled")}</td></tr>`;
      }

      function credentialRow(row) {
        return `<tr><td>${escapeHtml(row.name)}</td><td>${escapeHtml(row.username)}</td><td>${escapeHtml(row.user_email)}</td><td>${formatTime(row.last_used_at)}</td><td>${statePill(row.revoked_at ? "revoked" : "active")}</td><td>${row.revoked_at ? "" : `<button class="button" data-revoke="${escapeHtml(row.id)}">Revoke</button>`}</td></tr>`;
      }

      function eventRow(row) {
        return `<tr><td>${formatTime(row.ts)}</td><td>${statePill(row.status)}</td><td>${escapeHtml(row.envelope_from)}</td><td>${row.recipient_count}</td><td>${escapeHtml(row.smtp_code || "")}</td></tr>`;
      }

      function eventRowFull(row) {
        return `<tr><td>${formatTime(row.ts)}</td><td>${statePill(row.status)}</td><td>${escapeHtml(row.envelope_from)}</td><td>${row.recipient_count}</td><td>${escapeHtml(row.credential_id || row.api_key_id || "")}</td><td>${escapeHtml(row.error_code || row.cf_error_code || "")}</td></tr>`;
      }

      function failureRow(row) {
        return `<tr><td>${formatTime(row.ts)}</td><td>${escapeHtml(row.attempted_username || "")}</td><td>${escapeHtml(row.reason || "")}</td><td>${escapeHtml(row.source || "")}</td></tr>`;
      }

      function apiKeyRow(row) {
        return `<tr><td>${escapeHtml(row.name)}</td><td>${escapeHtml(row.key_prefix)}</td><td>${escapeHtml(row.user_email)}</td><td>${formatTime(row.last_used_at)}</td><td>${statePill(row.revoked_at ? "revoked" : "active")}</td></tr>`;
      }

      function statePill(value) {
        const normalized = String(value || "");
        const cls = ["accepted", "active", "enabled", "verified"].includes(normalized) ? "ok" : ["revoked", "disabled", "cf_error", "all_bounced"].includes(normalized) ? "bad" : "";
        return `<span class="pill ${cls}">${escapeHtml(normalized)}</span>`;
      }

      function formatTime(value) {
        return value ? new Date(Number(value) * 1000).toLocaleString() : "";
      }

      function escapeHtml(value) {
        return String(value ?? "").replace(/[&<>"']/g, (char) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;" })[char]);
      }
    </script>
  </body>
</html>
