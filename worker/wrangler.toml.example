# Copy to wrangler.toml and fill in the IDs that `pnpm setup` prints
# (or that you get from `wrangler d1 create` / `wrangler kv namespace create`).
#
# wrangler.toml is gitignored.

name = "cf-mail-relay-worker"
main = "src/index.ts"
compatibility_date = "2026-05-01"
compatibility_flags = ["nodejs_compat"]

# Bind the Worker to a custom hostname on a Cloudflare-managed zone.
# `pnpm run setup --apply` fills this in; for manual setups, change pattern to
# your zone.
routes = [
  { pattern = "mail.example.com", custom_domain = true },
]

# Worker schema version that the code expects to find in D1's settings table.
# Mismatch -> Worker boots with /healthz returning 500 + schema_version_mismatch.
[vars]
REQUIRED_D1_SCHEMA_VERSION = "5"
ACCESS_TEAM_DOMAIN = "your-team.cloudflareaccess.com"
ACCESS_AUDIENCE = "REPLACE_WITH_ACCESS_APPLICATION_AUD"
CF_ACCOUNT_ID = "REPLACE_WITH_CLOUDFLARE_ACCOUNT_ID"
RELAY_HMAC_KEY_ID = "rel_REPLACE_ME"
# Optional: only set when the admin UI is served from a different origin than
# the Worker (the default single-origin setup leaves this unset; the Worker
# defaults the trusted Origin to its own URL).
# ADMIN_CORS_ORIGIN = "https://admin.example.com"

[triggers]
crons = ["17 3 * * *"]

[observability.logs]
enabled = true
invocation_logs = true

# Admin UI is served same-origin via Workers Static Assets. `pnpm --filter ui
# build` writes the bundle into ./public/ which is uploaded with the Worker.
# Workers Static Assets handles GET/HEAD for matched files; the Worker's
# fetch handler runs first (run_worker_first) so /admin/api/*, /self/api/*,
# /relay/*, /send, /healthz, /bootstrap/admin are exclusively the Worker's,
# and unknown GETs fall through to /index.html via single-page-application
# routing for hash-route deep links.
[assets]
directory = "./public"
binding = "ASSETS"
not_found_handling = "single-page-application"
run_worker_first = true

[[d1_databases]]
binding = "D1_MAIN"
database_name = "cf-mail-relay"
database_id = "REPLACE_WITH_D1_DATABASE_ID"
migrations_dir = "migrations"

[[kv_namespaces]]
binding = "KV_HOT"
id = "REPLACE_WITH_KV_NAMESPACE_ID"

# Secrets are set via `wrangler secret put <NAME>`, not in this file:
#   CF_API_TOKEN
#   CREDENTIAL_PEPPER
#   METADATA_PEPPER
#   RELAY_HMAC_SECRET_CURRENT
#   RELAY_HMAC_SECRET_PREVIOUS  (optional, during rotation)
#   BOOTSTRAP_SETUP_TOKEN       (one-time)
