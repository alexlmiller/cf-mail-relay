{
  "name": "cf-mail-relay",
  "version": "0.0.0",
  "private": true,
  "description": "SMTP submission relay backed by Cloudflare Email Sending.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.22.3"
  },
  "scripts": {
    "build": "pnpm -r --filter='./worker' --filter='./ui' --filter='./shared' --filter='./demo' build",
    "typecheck": "pnpm -r --filter='./worker' --filter='./ui' --filter='./shared' --filter='./demo' typecheck",
    "test": "pnpm -r --filter='./worker' --filter='./shared' test && node --test infra/wrangler/*.test.mjs infra/setup/*.test.mjs",
    "demo:build": "pnpm --filter @cf-mail-relay/demo build",
    "demo:deploy": "pnpm --dir worker exec wrangler deploy --config ../demo/wrangler.toml",
    "setup": "node infra/wrangler/setup.mjs",
    "access:setup": "node infra/wrangler/access-app.mjs",
    "access:apply": "node infra/wrangler/access-apply.mjs",
    "access:verify": "node infra/wrangler/access-verify.mjs",
    "rotate:hmac": "node infra/wrangler/rotate-hmac.mjs",
    "doctor:local": "bash infra/setup/doctor-local.sh",
    "doctor:delivery": "bash infra/setup/doctor-delivery.sh",
    "screenshots": "tsx infra/screenshots/capture.ts"
  },
  "workspaces": [
    "worker",
    "ui",
    "demo",
    "shared"
  ],
  "pnpm": {
    "overrides": {
      "yaml": "^2.9.0"
    }
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "tsx": "^4.22.0"
  }
}
