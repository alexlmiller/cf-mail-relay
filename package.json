{
  "name": "cf-mail-relay",
  "version": "0.0.0",
  "private": true,
  "description": "SMTP submission relay backed by Cloudflare Email Sending.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --filter='./worker' --filter='./ui' --filter='./shared' build",
    "typecheck": "pnpm -r --filter='./worker' --filter='./ui' --filter='./shared' typecheck",
    "test": "pnpm -r --filter='./worker' --filter='./shared' test && node --test infra/wrangler/*.test.mjs infra/setup/*.test.mjs",
    "setup": "node infra/wrangler/setup.mjs",
    "access:setup": "node infra/wrangler/access-app.mjs",
    "access:apply": "node infra/wrangler/access-apply.mjs",
    "access:verify": "node infra/wrangler/access-verify.mjs",
    "rotate:hmac": "node infra/wrangler/rotate-hmac.mjs",
    "doctor:local": "bash infra/setup/doctor-local.sh",
    "doctor:delivery": "bash infra/setup/doctor-delivery.sh"
  },
  "workspaces": [
    "worker",
    "ui",
    "shared"
  ]
}
