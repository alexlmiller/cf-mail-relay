{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separateMajorReleases",
    "helpers:pinGitHubActionDigests"
  ],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "rangeStrategy": "bump",
  "internalChecksFilter": "strict",
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "packageRules": [
    {
      "description": "Wait before npm updates so newly published packages have time to be detected or retracted.",
      "matchDatasources": ["npm"],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Wait before Go module updates so newly published versions have time to be detected or retracted.",
      "matchDatasources": ["go"],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Keep GitHub Actions digest-pinned and reviewed as supply-chain-sensitive changes.",
      "matchManagers": ["github-actions"],
      "labels": ["dependencies", "github-actions"],
      "automerge": false
    },
    {
      "description": "Group non-major npm workspace updates.",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "npm non-major dependencies"
    },
    {
      "description": "Group non-major Go module updates.",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "go non-major dependencies"
    },
    {
      "description": "Keep Docker image updates explicit.",
      "matchManagers": ["dockerfile"],
      "labels": ["dependencies", "docker"],
      "automerge": false
    },
    {
      "description": "Require dashboard approval before major updates.",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "automerge": false
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"],
    "automerge": false
  }
}
